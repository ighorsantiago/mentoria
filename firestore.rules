rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuário só acessa os próprios dados
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Conversas e mensagens pertencem ao usuário
    match /users/{userId}/conversations/{convId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /messages/{msgId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Flashcards pertencem ao usuário
    match /users/{userId}/flashcards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Badges pertencem ao usuário
    match /users/{userId}/badges/{badgeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Sessões de estudo pertencem ao usuário
    match /users/{userId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
